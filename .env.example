# VTU Automator — Environment Configuration
# Copy this file to .env and adjust values if needed.
# All values below are optional — defaults work out of the box.

# How many lectures to complete in parallel (default: 3)
PARALLEL_LIMIT=3

# Seconds per progress chunk sent to server (default: 10)
CHUNK_SECONDS=10

# Delay between chunks in milliseconds (default: 250)
DELAY_MS=250

# Extra delay applied when lecture is >90% complete (default: 1200ms)
FINAL_DELAY=1200

# Server port (default: 5000)
PORT=5000

# Set to "true" to hide the automation browser window (default: false)
HEADLESS=false
